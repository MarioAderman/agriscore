# =============================================================================
# AgriScore — Variables de Entorno
# Copiar a .env y completar los valores necesarios
# =============================================================================

# -- Base de datos -----------------------------------------------------------
# Conexion PostgreSQL con PostGIS. Para desarrollo local:
DATABASE_URL=postgresql://agriscore:agriscore@localhost:5432/agriscore

# -- Proveedor LLM ----------------------------------------------------------
# Opciones: "bedrock" (produccion AWS), "anthropic" (API directa), "openai", "groq"
LLM_PROVIDER=anthropic
# Modelo especifico (vacio = default del proveedor)
LLM_MODEL=

# -- Anthropic (Claude) -----------------------------------------------------
# Requerido si LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# -- OpenAI ------------------------------------------------------------------
# Requerido para Whisper STT/TTS. Opcional como proveedor LLM.
OPENAI_API_KEY=

# -- Groq (opcional) ---------------------------------------------------------
# Inferencia rapida, compatible con OpenAI. Solo si LLM_PROVIDER=groq
GROQ_API_KEY=

# -- Sentinel Hub (Copernicus Data Space) ------------------------------------
# Datos satelitales NDVI. Obtener en https://dataspace.copernicus.eu/
SENTINEL_HUB_ID=
SENTINEL_HUB_SECRET=

# -- INEGI -------------------------------------------------------------------
# Datos socioeconomicos de Mexico. Obtener en https://www.inegi.org.mx/app/api/
INEGI_TOKEN=

# -- EvolutionAPI (WhatsApp) -------------------------------------------------
# URL del servicio EvolutionAPI y credenciales
EVOLUTIONAPI_URL=http://localhost:8080
EVOLUTIONAPI_AUTHENTICATION_API_KEY=
EVOLUTION_INSTANCE_NAME=Fintegra solutions

# -- AWS ---------------------------------------------------------------------
# Region y recursos. Solo necesario para despliegue en AWS.
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=agriscore-data
STEP_FUNCTIONS_ARN=
SAGEMAKER_ENDPOINT=

# -- Cognito (autenticacion de agricultores) ---------------------------------
# Solo necesario si se activa autenticacion JWT para endpoints /api/farmer/*
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# -- Aplicacion --------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
# API key para endpoints de instituciones financieras (/api/customer/*)
CUSTOMER_API_KEY=demo-customer-key
# CORS: origenes permitidos separados por coma (usar "*" solo en desarrollo)
ALLOWED_ORIGINS=*
